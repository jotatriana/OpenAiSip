# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_PROJECT_ID=proj_...
# Cheapest real-time model; change to gpt-4o-realtime-preview for higher quality
OPENAI_MODEL=gpt-realtime-mini
OPENAI_VOICE=alloy

# ── SIP Webhook ───────────────────────────────────────────────────────────────
# Signing secret from your OpenAI SIP project settings (Svix HMAC-SHA256)
WEBHOOK_SECRET=whsec_...

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_API_KEY=change-me-before-deploying

# ── Conversation behaviour ────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en-US
HUMAN_AGENT_SIP_URI=sip:queue@avaya.internal
ESCALATION_FRUSTRATION_LIMIT=3
ESCALATION_TOOL_FAILURE_LIMIT=2
MAX_TURNS_PER_PHASE=8
FRUSTRATION_KEYWORDS=speak to a person,speak to someone,speak to a manager,speak to a supervisor,talk to a real person,let me talk to someone,i want a human,transfer me,this is ridiculous,this is unacceptable,you're not helping,i'm going to cancel,i already told you,i've been waiting,i've called multiple times,get me a representative

# ── WebSocket resilience ──────────────────────────────────────────────────────
WS_PING_INTERVAL=10
WS_PING_TIMEOUT=5
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=300
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── Tool execution ────────────────────────────────────────────────────────────
TOOL_TIMEOUT_SECONDS=5.0

# ── Cost tracking ─────────────────────────────────────────────────────────────
# Pricing in USD per 1 000 tokens — update when OpenAI revises rates
COST_INPUT_AUDIO_PER_1K=0.10
COST_OUTPUT_AUDIO_PER_1K=0.20
COST_INPUT_TEXT_PER_1K=0.005
COST_OUTPUT_TEXT_PER_1K=0.02
COST_INPUT_CACHED_PER_1K=0.0025
# Hard stop: reject new calls when daily spend reaches this limit (0 = no limit)
DAILY_BUDGET_USD=0.0

# ── Warm handoff ──────────────────────────────────────────────────────────────
# Optional: POST escalation context to this URL for agent desktop integration
HANDOFF_CONTEXT_URL=

# ── Transfer timing ───────────────────────────────────────────────────────────
TRANSFER_HANGUP_DELAY_SECONDS=10

# ── Data retention ────────────────────────────────────────────────────────────
TRANSCRIPT_RETENTION_DAYS=90

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./openaisip.db
# PostgreSQL: pip install asyncpg, then uncomment:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/openaisip

# ── Server (defaults shown — only set to override) ───────────────────────────
# DASHBOARD_LISTEN_PORT=8001
# WEBHOOK_LISTEN_PORT=8000
# LOG_BUFFER_SIZE=500
# HEALTH_POLL_INTERVAL_SECONDS=10
# SIP_STALE_THRESHOLD_SECONDS=300
# WS_RECONNECT_BASE_MS=500
# WS_RECONNECT_MAX_MS=30000
# WS_RECONNECT_MAX_ATTEMPTS=15
